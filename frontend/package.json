{
    "name": "koshelf-frontend",
    "description": "React + Vite frontend for KoShelf.",
    "repository": "https://github.com/paviro/KOShelf",
    "license": "EUPL-1.2 license",
    "authors": [
        "Paul-Vincent Roll"
    ],
    "private": true,
    "version": "1.2.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "npm run i18n:check && tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "i18n:check": "node scripts/validate-locales.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@event-calendar/build": "^5.4.1",
        "@event-calendar/core": "^5.4.1",
        "@fluent/bundle": "^0.19.1",
        "@tanstack/react-query": "^5.66.4",
        "cldr-core": "^48.1.0",
        "i18n-iso-countries": "^7.14.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-icons": "^5.6.0",
        "react-router-dom": "^6.30.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "@fluent/syntax": "^0.19.0",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/typography": "^0.5.10",
        "@types/event-calendar__core": "^5.0.0",
        "@types/node": "^25.3.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.4.1",
        "eslint": "^9.39.3",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^6.0.11"
    }
}
