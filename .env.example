# Your certificate name
# You can find valid IDs by using: security find-identity -v -p codesigning
APPLE_DEVELOPER_ID="Developer ID Application: Your Name (ID1234)"

# The name of a notarytool keychain profile. The credentials live in the
# keychain, not this file. Create it once (the command prompts for the password):
#   xcrun notarytool store-credentials <name> --apple-id <apple-id> --team-id <team-id>
APPLE_NOTARY_PROFILE="my-notary-profile"
